{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django: runserver (getion_glovo)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": ["runserver", "127.0.0.1:8000"],
      "django": true,
      "cwd": "${workspaceFolder}",
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings"
      },
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
